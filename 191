    keyAttempts = keyAttempts + 1
    
    if inputKey == correctKey then
        keyVerified = true
        KeyStatus.Text = "✅ KEY BENAR! Loading Hub..."
        KeyStatus.TextColor3 = Color3.fromRGB(100,255,100)
        
        -- Animasi keluar key frame
        TweenService:Create(KeyFrame, TweenInfo.new(0.5), {
            BackgroundTransparency = 1,
            Size = UDim2.new(0,0,0,0)
        }):Play()
        
        task.wait(0.5)
        KeyFrame.Visible = false
        
        -- Tampilkan main frame dengan animasi
        MainFrame.Visible = true
        MainFrame.Size = UDim2.new(0,0,0,0)
        task.wait(0.1)
        TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {
            Size = UDim2.new(0,300,0,500)
        }):Play()
        
        -- Play sound effect (opsional)
        -- game:GetService("SoundService"):Play("rbxassetid://9120381772")
    else
        local remainingAttempts = maxAttempts - keyAttempts
        if remainingAttempts > 0 then
            KeyStatus.Text = string.format("❌ KEY SALAH! Sisa percobaan: %d", remainingAttempts)
            KeyStatus.TextColor3 = Color3.fromRGB(255,100,100)
        else
            KeyStatus.Text = "❌ PERCOBAAN HABIS! HUB DIKUNCI"
            KeyStatus.TextColor3 = Color3.fromRGB(255,0,0)
            KeyButton.Visible = false
            KeyBox.Visible = false
            
            -- Kunci hub selama 60 detik
            task.wait(60)
            keyAttempts = 0
            KeyButton.Visible = true
            KeyBox.Visible = true
            KeyStatus.Text = ""
        end
    end
end

