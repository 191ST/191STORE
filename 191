-- AUTO BUY FUNCTIONS
function buyMaterial(material)
    if not keyVerified then return false end
    
    -- METHOD 1: Click Detector (paling umum)
    local workspace = game:GetService("Workspace")
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ClickDetector") and v.Parent and v.Parent.Name:lower():find(material:lower()) then
            fireclickdetector(v)
            return true
        end
    end
    
    -- METHOD 2: Remote Event (umum di game modern)
    for _, v in ipairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") and v.Name:lower():find("buy") or v.Name:lower():find("purchase") then
            v:FireServer(material)
            return true
        end
    end
    
    -- METHOD 3: Proximity Prompt
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Parent and v.Parent.Name:lower():find(material:lower()) then
            v:InputHoldBegin()
            task.wait(0.5)
            v:InputHoldEnd()
            return true
        end
    end
    
    return false
end

function startAutoBuy()
