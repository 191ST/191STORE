-- MS Loop Function
function startMSLoop()
    if not keyVerified then return end
    if loopRunning then return end
    loopRunning = true
    MSLoopStatus.Text = "▶️ LOOP RUNNING"
    MSLoopStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while loopRunning do
        -- Step 1: Hold E (Water) - 20 seconds
        MSLoopStepLabel.Text = "Current Step: Water (Hold E) - 20s"
        for i = 20, 1, -1 do
            MSLoopTimer.Text = "Timer: " .. i .. "s"
            task.wait(1)
            if not loopRunning then break end
        end
        if not loopRunning then break end
        holdKey(Enum.KeyCode.E, 0.1)
        
        -- Step 2: Hold E (Sugar) - 1 second
        MSLoopStepLabel.Text = "Current Step: Sugar (Hold E) - 1s"
        MSLoopTimer.Text = "Timer: 1s"
        task.wait(1)
        if not loopRunning then break end
        holdKey(Enum.KeyCode.E, 0.1)
        
        -- Step 3: Hold E (Gelatin) - 45 seconds
        MSLoopStepLabel.Text = "Current Step: Gelatin (Hold E) - 45s"
        for i = 45, 1, -1 do
            MSLoopTimer.Text = "Timer: " .. i .. "s"
            task.wait(1)
            if not loopRunning then break end
        end
        if not loopRunning then break end
        holdKey(Enum.KeyCode.E, 0.1)
        
        -- Step 4: Hold E (Empty Bag) - 1 second
        MSLoopStepLabel.Text = "Current Step: Empty Bag (Hold E) - 1s"
        MSLoopTimer.Text = "Timer: 1s"
        task.wait(1)
        if not loopRunning then break end
        holdKey(Enum.KeyCode.E, 0.1)
        
        MSLoopStepLabel.Text = "Current Step: Loop Complete - Restarting"
        task.wait(0.5)
    end
    
    MSLoopStatus.Text = "⏹️ LOOP STOPPED"
    MSLoopStatus.TextColor3 = Color3.fromRGB(255,100,100)
    MSLoopStepLabel.Text = "Current Step: Stopped"
    MSLoopTimer.Text = "Timer: 0s"
end

