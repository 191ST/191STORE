-- VARIABLES
local loopRunning = false
local steps = {
    {name = "Water", duration = 20},
    {name = "Sugar", duration = 1},
    {name = "Gelatin", duration = 45},
    {name = "Empty Bag", duration = 1}
}

-- FUNCTIONS
function TP_MS()
    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.CFrame = CFrame.new(521.32,47.79,617.25)
    end
end

function holdE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.2)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

function MSLoop()
    loopRunning = true
    StatusLabel.Text = "▶️ LOOP RUNNING"
    StatusLabel.TextColor3 = Color3.fromRGB(100,255,100)
    
    while loopRunning do
        for i, step in ipairs(steps) do
            if not loopRunning then break end
            
            StepLabel.Text = "Step: " .. step.name .. " (Hold E)"
            
            -- Countdown timer
            for t = step.duration, 1, -1 do
                if not loopRunning then break end
                TimerLabel.Text = "Timer: " .. t .. "s"
                task.wait(1)
            end
            
            if loopRunning then
                holdE()
                task.wait(0.3)
            end
        end
        
        if loopRunning then
            StepLabel.Text = "Step: Loop Complete - Restarting"
            task.wait(1)
        end
    end
    
    -- Reset UI saat stop
    StatusLabel.Text = "⏹️ LOOP STOPPED"
    StatusLabel.TextColor3 = Color3.fromRGB(255,100,100)
    StepLabel.Text = "Step: Idle"
    TimerLabel.Text = "Timer: 0s"
end

-- BUTTON CONNECTIONS
StartBtn.MouseButton1Click:Connect(function()
    if not loopRunning then
        task.spawn(MSLoop)
    end
end)

StopBtn.MouseButton1Click:Connect(function()
    loopRunning = false
end)

TPBtn.MouseButton1Click:Connect(TP_MS)

-- MINIMIZE SYSTEM
local minimized = false
local openSize = UDim2.new(0,300,0,250)
local closedSize = UDim2.new(0,300,0,40)

MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    
    if minimized then
        Content.Visible = false
        MinBtn.Text = "□"
        TweenService:Create(Frame, TweenInfo.new(0.3), {Size = closedSize}):Play()
    else
        TweenService:Create(Frame, TweenInfo.new(0.3), {Size = openSize}):Play()
        task.wait(0.3)
        Content.Visible = true
        MinBtn.Text = "−"
    end
end)

-- KEYBOARD MINIMIZE (Z)
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Z then
        minimized = not minimized
        if minimized then
            Content.Visible = false
            MinBtn.Text = "□"
            TweenService:Create(Frame, TweenInfo.new(0.3), {Size = closedSize}):Play()
        else
            TweenService:Create(Frame, TweenInfo.new(0.3), {Size = openSize}):Play()
            task.wait(0.3)
            Content.Visible = true
            MinBtn.Text = "−"
        end
    end
end)

