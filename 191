    autoBuyRunning = true
    currentCount = 0
    AutoBuyStatus.Text = "💰 RUNNING"
    AutoBuyStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while autoBuyRunning and currentCount < targetAmount do
        local success = false
        
        if buyWater then
            AutoBuyProgress.Text = string.format("Buying Water... (%d/%d)", currentCount, targetAmount)
            if buyMaterial("water") then
                success = true
            end
            task.wait(0.5)
        end
        
        if buySugar then
            AutoBuyProgress.Text = string.format("Buying Sugar... (%d/%d)", currentCount, targetAmount)
            if buyMaterial("sugar") then
                success = true
            end
            task.wait(0.5)
        end
        
        if buyGelatin then
            AutoBuyProgress.Text = string.format("Buying Gelatin... (%d/%d)", currentCount, targetAmount)
            if buyMaterial("gelatin") then
                success = true
            end
            task.wait(0.5)
        end
        
        if success then
            currentCount = currentCount + 1
            AutoBuyProgress.Text = string.format("Progress: %d/%d", currentCount, targetAmount)
            SliderFill.Size = UDim2.new(currentCount/targetAmount, 0, 1, 0)
        end
        
        task.wait(1)
    end
    
    autoBuyRunning = false
    AutoBuyStatus.Text = "⏹️ STOPPED"
    AutoBuyStatus.TextColor3 = Color3.fromRGB(255,100,100)
    if currentCount >= targetAmount then
        AutoBuyProgress.Text = string.format("COMPLETE! (%d/%d)", currentCount, targetAmount)
    end
end

AutoBuyButton.MouseButton1Click:Connect(function()
    if not autoBuyRunning then
        task.spawn(startAutoBuy)
    else
        autoBuyRunning = false
    end
end)

