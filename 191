-- Hold Key Function
function holdKey(keyCode, duration)
    VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    task.wait(duration)
    VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
end

-- GUI Click Function (NEW - Untuk Auto Buy GUI Mode)
function guiClick()
    -- Simulasi klik pada GUI button (jika ada)
    -- Ini akan mencari button yang sesuai di layar
    local mouse = player:GetMouse()
    
    -- Coba trigger RemoteEvent jika ada (untuk game tertentu)
    local args = {
        [1] = "BuyItem",
        [2] = selectedItem
    }
    
    -- Coba berbagai kemungkinan remote event
    local remote = ReplicatedStorage:FindFirstChild("BuyItem") or
                   ReplicatedStorage:FindFirstChild("Purchase") or
                   ReplicatedStorage:FindFirstChild("Buy")
    
    if remote and remote:IsA("RemoteEvent") then
        remote:FireServer(unpack(args))
    else
        -- Fallback: klik pada posisi tertentu (perlu disesuaikan dengan game)
        VirtualInputManager:SendMouseButtonEvent(500, 300, 0, true, game, 0)
        task.wait(0.1)
        VirtualInputManager:SendMouseButtonEvent(500, 300, 0, false, game, 0)
    end
end

-- Enhanced Auto Buy Function (GUI Optimized)
function startAutoBuy()
    if autoBuyRunning then return end
    autoBuyRunning = true
    currentBuyCount = 0
    AutoBuyStatus.Text = string.format("💰 AUTO BUY RUNNING - Buying %s", selectedItem)
    AutoBuyStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while autoBuyRunning and currentBuyCount < targetAmount do
        AutoBuyProgress.Text = string.format("Progress: %d/%d - Buying %s...", 
            currentBuyCount + 1, targetAmount, selectedItem)
        
        if buyMethod == "HOLD" then
            -- Method HOLD (tekan E)
            holdKey(Enum.KeyCode.E, 0.3)
        else
            -- Method CLICK (GUI click simulation)
            guiClick()
        end
        
        task.wait(buyDelay)
        
        currentBuyCount = currentBuyCount + 1
        AutoBuyProgress.Text = string.format("Progress: %d/%d - Completed", currentBuyCount, targetAmount)
        SliderFill.Size = UDim2.new(currentBuyCount / targetAmount, 0, 1, 0)
        
        -- Update fill color based on progress
        if currentBuyCount >= targetAmount then
            SliderFill.BackgroundColor3 = Color3.fromRGB(100,255,100)
        end
        
        task.wait(0.2)
    end
    
    autoBuyRunning = false
    AutoBuyStatus.Text = string.format("⏹️ AUTO BUY STOPPED - Target: %d/%d", currentBuyCount, targetAmount)
    AutoBuyStatus.TextColor3 = Color3.fromRGB(255,100,100)
    
    if currentBuyCount >= targetAmount then
        AutoBuyProgress.Text = string.format("Progress: %d/%d - COMPLETE! 🎉", currentBuyCount, targetAmount)
        SliderFill.BackgroundColor3 = Color3.fromRGB(100,255,100)
    end
end

