-- MS LOOP FUNCTIONS
function startMSLoop()
    if not keyVerified then return end
    loopRunning = true
    MSLoopStatus.Text = "▶️ RUNNING"
    MSLoopStatus.TextColor3 = Color3.fromRGB(100,255,100)
    
    while loopRunning do
        -- Water (20 detik)
        MSLoopStep.Text = "Step: Water - Hold E (20s)"
        for i = 20, 1, -1 do
            MSLoopTimer.Text = "Timer: " .. i .. "s"
            task.wait(1)
            if not loopRunning then break end
        end
        if loopRunning then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.5)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        else break end
        
        -- Sugar (1 detik)
        MSLoopStep.Text = "Step: Sugar - Hold E (1s)"
        MSLoopTimer.Text = "Timer: 1s"
        task.wait(1)
        if loopRunning then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.5)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        else break end
        
        -- Gelatin (45 detik)
        MSLoopStep.Text = "Step: Gelatin - Hold E (45s)"
        for i = 45, 1, -1 do
            MSLoopTimer.Text = "Timer: " .. i .. "s"
            task.wait(1)
            if not loopRunning then break end
        end
        if loopRunning then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.5)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        else break end
        
        -- Empty Bag (1 detik)
        MSLoopStep.Text = "Step: Empty Bag - Hold E (1s)"
        MSLoopTimer.Text = "Timer: 1s"
        task.wait(1)
        if loopRunning then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.5)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        else break end
    end
    
    MSLoopStatus.Text = "⏹️ STOPPED"
    MSLoopStatus.TextColor3 = Color3.fromRGB(255,100,100)
    MSLoopStep.Text = "Step: Idle"
    MSLoopTimer.Text = "Timer: 0s"
end

