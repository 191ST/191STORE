-- Item Buttons
local ItemButtons = {}
local items = {
    {name = "Water", color = Color3.fromRGB(0,150,255), key = Enum.KeyCode.E},
    {name = "Sugar", color = Color3.fromRGB(255,150,0), key = Enum.KeyCode.E},
    {name = "Gelatin", color = Color3.fromRGB(150,255,150), key = Enum.KeyCode.E},
    {name = "Empty Bag", color = Color3.fromRGB(200,200,200), key = Enum.KeyCode.E}
}

local selectedItem = "Water" -- Default selection

for i, item in ipairs(items) do
    local btn = Instance.new("TextButton")
    btn.Parent = ItemSelectFrame
    btn.Name = item.name .. "Btn"
    btn.Size = UDim2.new(0.25,-8,0,35)
    btn.Position = UDim2.new((i-1)*0.25, 4, 0, 35)
    btn.BackgroundColor3 = (i == 1) and Color3.fromRGB(80,80,100) or Color3.fromRGB(50,50,60)
    btn.Text = item.name
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.Parent = btn
    btnCorner.CornerRadius = UDim.new(0,6)
    
    table.insert(ItemButtons, btn)
    
    btn.MouseButton1Click:Connect(function()
        selectedItem = item.name
        -- Update button colors
        for _, b in ipairs(ItemButtons) do
            b.BackgroundColor3 = Color3.fromRGB(50,50,60)
        end
        btn.BackgroundColor3 = Color3.fromRGB(80,80,100)
        
        -- Update status
        AutoBuyStatus.Text = "⏹️ AUTO BUY STOPPED - Selected: " .. selectedItem
    end)
end

